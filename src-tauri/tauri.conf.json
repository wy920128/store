{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "store",
  "version": "1.0.0",
  "identifier": "com.wy.store",
  "build": {
    "beforeDevCommand": "yarn vite",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "yarn build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "内网应用商店",
        "width": 1000,
        "height": 750,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "deb",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
