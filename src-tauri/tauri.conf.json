{
  "build": {
    "beforeBuildCommand": "yarn build",
    "beforeDevCommand": "yarn dev",
    "devPath": "http://localhost:5173",
    "distDir": "../dist"
  },
  "package": {
    "productName": "store",
    "version": "0.0.1"
  },
  "tauri": {
    "allowlist": {
      "shell": {
        "execute": true
      }
    },
    "bundle": {
      "active": true,
      "category": "Utility",
      "copyright": "wangye",
      "deb": {
        "depends": [
          "apt",
          "libgtk-3-0",
          "libwebkit2gtk-4.0-37",
          "policykit-1"
        ]
      },
      "externalBin": [],
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "identifier": "com.jms.wy.store",
      "longDescription": "基于内网的应用商店，支持软件安装",
      "shortDescription": "应用商店",
      "macOS": {
        "entitlements": null,
        "exceptionDomain": "",
        "frameworks": [],
        "providerShortName": null,
        "signingIdentity": null
      },
      "resources": [],
      "targets": [
        "deb"
      ],
      "windows": {
        "certificateThumbprint": null,
        "digestAlgorithm": "sha256",
        "timestampUrl": ""
      }
    },
    "security": {
      "csp": null
    },
    "updater": {
      "active": false
    },
    "windows": [
      {
        "fullscreen": false,
        "height": 900,
        "resizable": false,
        "title": "应用商店",
        "width": 1000
      }
    ]
  }
}